"----------------------------
" Generic settings
"----------------------------

set nocompatible  " Use Vim defaults (not Vi compatibility)
filetype plugin indent on  " Enable filetype detection, plugins, and indentation

set tabstop=2     " Display width of a tab character
set expandtab     " Insert spaces instead of actual tab characters
set shiftwidth=2  " Indent size for >> and <<
set autoindent    " Copy indent from current line
set smartindent   " Smarter auto-indenting for code
set paste         " Avoid auto-indent while pasting (toggle off after paste)
set nu            " Show line numbers
set mouse=a       " Enable mouse in all modes
syntax on         " Enable syntax highlighting
set wrap          " Wrap long lines

"--------
" vim-plug
"--------
" Installs plugins into ~/.vim/plugged/
" Bootstrap vim-plug if missing
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !mkdir -p ~/.vim/autoload
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
        \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  augroup PlugBootstrap
    autocmd!
    autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
  augroup END
endif

call plug#begin('~/.vim/plugged')

" Plugins
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-surround'
Plug 'preservim/nerdtree'              " NERDTree (moved from scrooloose/)
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'kien/ctrlp.vim'
Plug 'nathangrigg/vim-beancount'
Plug 'tpope/vim-obsession'

call plug#end()

"-------------------
" Optional local overrides
"-------------------

if filereadable(expand('~/.vimrc.local'))
  source ~/.vimrc.local
endif
